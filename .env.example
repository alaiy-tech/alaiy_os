# =============================================================================
# AlaiyOS Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values for your deployment.
# .env is git-ignored and must NEVER be committed.
#
# Usage:
#   cp .env.example .env
#   nano .env   (fill in your values)
# =============================================================================

# -----------------------------------------------------------------------------
# Company (used for ERPNext onboarding — written to DB once on install)
# -----------------------------------------------------------------------------
COMPANY_NAME=
COMPANY_ABBR=
# Currency code — INR for India, USD for US
COMPANY_CURRENCY=
# Must match an ERPNext-supported country name exactly e.g. "India", "United States"
COMPANY_COUNTRY=

# -----------------------------------------------------------------------------
# Cloudstore / The Corner supplier connector
# -----------------------------------------------------------------------------
CLOUDSTORE_ENABLED=false
# Sandbox:    https://sandbox.csplatform.io:9950
# Production: http://api.fashiondealer.net  (flag supplier to enable HTTPS)
CLOUDSTORE_API_URL=
# Bearer token from Cloudstore — get from supplier
CLOUDSTORE_API_TOKEN=
# ERPNext master data — created automatically on install
CLOUDSTORE_SUPPLIER_NAME=The Corner
CLOUDSTORE_SUPPLIER_COUNTRY=Italy
CLOUDSTORE_PRICE_LIST_NAME=Cloudstore Supplier Price
CLOUDSTORE_PRICE_LIST_CURRENCY=EUR
CLOUDSTORE_WAREHOUSE_NAME=Altomoda Stores
# How many products to fetch per API page during sync (max 250)
CLOUDSTORE_PAGE_SIZE=50

# -----------------------------------------------------------------------------
# Shopify connector
# -----------------------------------------------------------------------------
SHOPIFY_ENABLED=false
# e.g. your-store.myshopify.com (no https://)
SHOPIFY_SHOP_URL=
# Private app access token (shpat_...)
SHOPIFY_ACCESS_TOKEN=
SHOPIFY_WAREHOUSE_NAME=

# -----------------------------------------------------------------------------
# Myntra connector
# -----------------------------------------------------------------------------
MYNTRA_ENABLED=false
MYNTRA_API_URL=
MYNTRA_API_KEY=
MYNTRA_WAREHOUSE_NAME=

# -----------------------------------------------------------------------------
# Amazon connector
# -----------------------------------------------------------------------------
AMAZON_ENABLED=false
AMAZON_SELLER_ID=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_MARKETPLACE_ID=
AMAZON_WAREHOUSE_NAME=
